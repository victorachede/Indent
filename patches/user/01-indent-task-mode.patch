+/*---------------------------------------------------------------------------------------------
+ *  Indent – Task Mode view pane
+ *  Input at bottom, status flickers above it, brief fills the space above that.
+ *--------------------------------------------------------------------------------------------*/
+
+import { $, append, clearNode } from '../../../../base/browser/dom.js';
+import { IViewPaneOptions, ViewPane } from '../../../browser/parts/views/viewPane.js';
+import { IKeybindingService } from '../../../../platform/keybinding/common/keybinding.js';
+import { IContextMenuService } from '../../../../platform/contextview/browser/contextView.js';
+import { IConfigurationService } from '../../../../platform/configuration/common/configuration.js';
+import { IContextKeyService } from '../../../../platform/contextkey/common/contextkey.js';
+import { IViewDescriptorService } from '../../../common/views.js';
+import { IInstantiationService } from '../../../../platform/instantiation/common/instantiation.js';
+import { IOpenerService } from '../../../../platform/opener/common/opener.js';
+import { IThemeService } from '../../../../platform/theme/common/themeService.js';
+import { ITelemetryService } from '../../../../platform/telemetry/common/telemetry.js';
+import { IHoverService } from '../../../../platform/hover/browser/hover.js';
+import { IndentAgentService, IAgentBrief } from './indentAgentService.js';
+
+const STATUS_MESSAGES = [
+	'reading codebase',
+	'checking docs',
+	'planning',
+	'thinking harder',
+	'picked approach',
+];
+
+export class IndentAgentViewPane extends ViewPane {
+
+	private container!: HTMLElement;
+	private briefArea!: HTMLElement;
+	private statusLine!: HTMLElement;
+	private inputWrapper!: HTMLElement;
+	private textarea!: HTMLTextAreaElement;
+	private submitBtn!: HTMLButtonElement;
+
+	private agentService!: IndentAgentService;
+	private statusInterval: ReturnType<typeof setInterval> | undefined;
+	private isRunning = false;
+
+	constructor(
+		options: IViewPaneOptions,
+		@IKeybindingService keybindingService: IKeybindingService,
+		@IContextMenuService contextMenuService: IContextMenuService,
+		@IConfigurationService configurationService: IConfigurationService,
+		@IContextKeyService contextKeyService: IContextKeyService,
+		@IViewDescriptorService viewDescriptorService: IViewDescriptorService,
+		@IInstantiationService instantiationService: IInstantiationService,
+		@IOpenerService openerService: IOpenerService,
+		@IThemeService themeService: IThemeService,
+		@ITelemetryService telemetryService: ITelemetryService,
+		@IHoverService hoverService: IHoverService,
+	) {
+		super(options, keybindingService, contextMenuService, configurationService, contextKeyService, viewDescriptorService, instantiationService, openerService, themeService, telemetryService, hoverService);
+	}
+
+	protected override renderBody(container: HTMLElement): void {
+		super.renderBody(container);
+		this.container = container;
+		this.agentService = this._register(this.instantiationService.createInstance(IndentAgentService));
+		container.classList.add('indent-agent-pane');
+
+		this.briefArea = append(container, $('.indent-agent-brief'));
+		this.briefArea.setAttribute('aria-live', 'polite');
+
+		this.statusLine = append(container, $('.indent-agent-status'));
+		this.statusLine.textContent = '';
+
+		this.inputWrapper = append(container, $('.indent-agent-input-wrapper'));
+
+		this.textarea = append(this.inputWrapper, $('textarea.indent-agent-input')) as HTMLTextAreaElement;
+		this.textarea.placeholder = 'What do you want to build?';
+		this.textarea.rows = 2;
+		this.textarea.setAttribute('aria-label', 'Task input');
+
+		this.submitBtn = append(this.inputWrapper, $('button.indent-agent-submit')) as HTMLButtonElement;
+		this.submitBtn.textContent = '↵';
+		this.submitBtn.setAttribute('aria-label', 'Run task');
+
+		this._register(this.agentService.onStatusUpdate(msg => this.setStatus(msg)));
+		this._register(this.agentService.onBriefReady(brief => this.showBrief(brief)));
+		this._register(this.agentService.onError(err => this.showError(err)));
+
+		this.textarea.addEventListener('keydown', (e) => {
+			if (e.key === 'Enter' && !e.shiftKey) {
+				e.preventDefault();
+				this.runTask();
+			}
+		});
+
+		this.submitBtn.addEventListener('click', () => this.runTask());
+	}
+
+	private runTask(): void {
+		const task = this.textarea.value.trim();
+		if (!task || this.isRunning) { return; }
+		this.isRunning = true;
+		this.textarea.disabled = true;
+		this.submitBtn.disabled = true;
+		clearNode(this.briefArea);
+		this.startStatusFlicker();
+		this.agentService.runTask(task);
+	}
+
+	private startStatusFlicker(): void {
+		let i = 0;
+		this.setStatus(STATUS_MESSAGES[0]);
+		this.statusInterval = setInterval(() => {
+			i = (i + 1) % STATUS_MESSAGES.length;
+			this.setStatus(STATUS_MESSAGES[i]);
+		}, 1800);
+	}
+
+	private stopStatusFlicker(): void {
+		if (this.statusInterval) {
+			clearInterval(this.statusInterval);
+			this.statusInterval = undefined;
+		}
+	}
+
+	private setStatus(msg: string): void {
+		this.statusLine.textContent = msg;
+	}
+
+	private showBrief(brief: IAgentBrief): void {
+		this.stopStatusFlicker();
+		this.setStatus('');
+		clearNode(this.briefArea);
+
+		const fileList = append(this.briefArea, $('.indent-brief-files'));
+		const header = append(fileList, $('.indent-brief-header'));
+		header.textContent = `${brief.files.length} file${brief.files.length !== 1 ? 's' : ''}  ·  ${brief.totalChanges} change${brief.totalChanges !== 1 ? 's' : ''}`;
+
+		for (const f of brief.files) {
+			const row = append(fileList, $('.indent-brief-file-row'));
+			const path = append(row, $('.indent-brief-file-path'));
+			path.textContent = f.path;
+			const reason = append(row, $('.indent-brief-file-reason'));
+			reason.textContent = f.reason;
+		}
+
+		if (brief.commendation) {
+			const note = append(this.briefArea, $('.indent-brief-commendation'));
+			note.textContent = brief.commendation;
+		}
+
+		const actions = append(this.briefArea, $('.indent-brief-actions'));
+
+		const editBtn = append(actions, $('button.indent-brief-btn-secondary')) as HTMLButtonElement;
+		editBtn.textContent = 'Edit plan';
+		editBtn.addEventListener('click', () => this.resetToInput());
+
+		const goBtn = append(actions, $('button.indent-brief-btn-primary')) as HTMLButtonElement;
+		goBtn.textContent = 'Go';
+		goBtn.addEventListener('click', () => this.executePlan(brief));
+	}
+
+	private showError(msg: string): void {
+		this.stopStatusFlicker();
+		this.setStatus('');
+		clearNode(this.briefArea);
+		const err = append(this.briefArea, $('.indent-brief-error'));
+		err.textContent = msg;
+		this.resetInputState();
+	}
+
+	private async executePlan(brief: IAgentBrief): Promise<void> {
+		clearNode(this.briefArea);
+		this.setStatus('building');
+		await this.agentService.executePlan(brief);
+		this.setStatus('done');
+		setTimeout(() => this.resetToInput(), 2000);
+	}
+
+	private resetToInput(): void {
+		this.stopStatusFlicker();
+		this.setStatus('');
+		clearNode(this.briefArea);
+		this.resetInputState();
+	}
+
+	private resetInputState(): void {
+		this.isRunning = false;
+		this.textarea.disabled = false;
+		this.submitBtn.disabled = false;
+		this.textarea.value = '';
+		this.textarea.focus();
+	}
+
+	protected override layoutBody(height: number, width: number): void {
+		super.layoutBody(height, width);
+	}
+
+	override dispose(): void {
+		this.stopStatusFlicker();
+		super.dispose();
+	}
+}
