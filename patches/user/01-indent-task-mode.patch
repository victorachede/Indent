+/*---------------------------------------------------------------------------------------------
+ *  Indent – Agent service
+ *  Talks to Claude API, reads workspace files, builds the brief.
+ *--------------------------------------------------------------------------------------------*/
+
+import { Disposable } from '../../../../base/common/lifecycle.js';
+import { Emitter, Event } from '../../../../base/common/event.js';
+import { IWorkspaceContextService } from '../../../../platform/workspace/common/workspace.js';
+import { IFileService } from '../../../../platform/files/common/files.js';
+import { URI } from '../../../../base/common/uri.js';
+
+const CLAUDE_API_URL = 'https://api.anthropic.com/v1/messages';
+const CLAUDE_MODEL = 'claude-sonnet-4-6';
+const MAX_FILE_BYTES = 80000;
+const MAX_FILES = 20;
+
+export interface IAgentBrief {
+	files: Array<{ path: string; reason: string }>;
+	totalChanges: number;
+	commendation?: string;
+	rawPlan: string;
+}
+
+export class IndentAgentService extends Disposable {
+
+	private readonly _onStatusUpdate = this._register(new Emitter<string>());
+	readonly onStatusUpdate: Event<string> = this._onStatusUpdate.event;
+
+	private readonly _onBriefReady = this._register(new Emitter<IAgentBrief>());
+	readonly onBriefReady: Event<IAgentBrief> = this._onBriefReady.event;
+
+	private readonly _onError = this._register(new Emitter<string>());
+	readonly onError: Event<string> = this._onError.event;
+
+	constructor(
+		@IWorkspaceContextService private readonly workspaceService: IWorkspaceContextService,
+		@IFileService private readonly fileService: IFileService,
+	) {
+		super();
+	}
+
+	async runTask(task: string): Promise<void> {
+		try {
+			this._onStatusUpdate.fire('reading codebase');
+			const codebaseSnapshot = await this.readWorkspaceFiles();
+			this._onStatusUpdate.fire('planning');
+			const brief = await this.callClaude(task, codebaseSnapshot);
+			this._onBriefReady.fire(brief);
+		} catch (err: unknown) {
+			const msg = err instanceof Error ? err.message : String(err);
+			this._onError.fire(`Something went wrong: ${msg}`);
+		}
+	}
+
+	private async readWorkspaceFiles(): Promise<string> {
+		const folders = this.workspaceService.getWorkspace().folders;
+		if (!folders.length) { return '(no workspace open)'; }
+		const root = folders[0].uri;
+		const files = await this.collectFiles(root, 0);
+		const parts: string[] = [];
+		for (const uri of files.slice(0, MAX_FILES)) {
+			try {
+				const content = await this.fileService.readFile(uri);
+				const text = content.value.slice(0, MAX_FILE_BYTES).toString();
+				const rel = uri.path.replace(root.path, '').replace(/^\//, '');
+				parts.push(`=== ${rel} ===\n${text}`);
+			} catch {
+				// skip unreadable files
+			}
+		}
+		return parts.join('\n\n');
+	}
+
+	private async collectFiles(dir: URI, depth: number): Promise<URI[]> {
+		if (depth > 4) { return []; }
+		const results: URI[] = [];
+		try {
+			const stat = await this.fileService.resolve(dir);
+			if (!stat.children) { return []; }
+			for (const child of stat.children) {
+				if (this.shouldSkip(child.name)) { continue; }
+				if (child.isDirectory) {
+					results.push(...await this.collectFiles(child.resource, depth + 1));
+				} else if (this.isSourceFile(child.name)) {
+					results.push(child.resource);
+				}
+			}
+		} catch {
+			// skip
+		}
+		return results;
+	}
+
+	private shouldSkip(name: string): boolean {
+		return ['node_modules', '.git', 'dist', 'build', '.next', 'out', '.cache', 'coverage'].includes(name);
+	}
+
+	private isSourceFile(name: string): boolean {
+		return /\.(ts|tsx|js|jsx|py|rs|go|java|c|cpp|h|css|scss|html|json|md|toml|yaml|yml|prisma|sql)$/.test(name);
+	}
+
+	private async callClaude(task: string, codebase: string): Promise<IAgentBrief> {
+		const apiKey = this.getApiKey();
+		if (!apiKey) {
+			throw new Error('No Anthropic API key set. Go to Settings → Indent → API Key.');
+		}
+
+		const systemPrompt = `You are Indent's agent — a precise, confident coding assistant.
+You will receive a task and a codebase snapshot.
+Think through multiple approaches internally. Pick the best one.
+Return ONLY valid JSON matching this exact shape, no prose, no markdown:
+{
+  "files": [{ "path": "relative/path", "reason": "one line" }],
+  "totalChanges": <number>,
+  "commendation": "<optional honest codebase observation, omit key if nothing to say>",
+  "rawPlan": "<your full plan>"
+}
+Be direct. If the codebase is solid say so. If it needs work say that too.`;
+
+		const response = await fetch(CLAUDE_API_URL, {
+			method: 'POST',
+			headers: {
+				'Content-Type': 'application/json',
+				'x-api-key': apiKey,
+				'anthropic-version': '2023-06-01',
+			},
+			body: JSON.stringify({
+				model: CLAUDE_MODEL,
+				max_tokens: 1024,
+				system: systemPrompt,
+				messages: [{ role: 'user', content: `Task: ${task}\n\nCodebase:\n${codebase}` }],
+			}),
+		});
+
+		if (!response.ok) {
+			throw new Error(`Claude API ${response.status}: ${await response.text()}`);
+		}
+
+		const data = await response.json() as { content: Array<{ type: string; text: string }> };
+		const text = data.content.find(b => b.type === 'text')?.text ?? '';
+
+		try {
+			return JSON.parse(text) as IAgentBrief;
+		} catch {
+			throw new Error('Agent returned a malformed plan. Try again.');
+		}
+	}
+
+	async executePlan(_brief: IAgentBrief): Promise<void> {
+		await new Promise<void>(r => setTimeout(r, 1200));
+	}
+
+	private getApiKey(): string {
+		try {
+			const val = (globalThis as Record<string, unknown>)['indentApiKey'];
+			return typeof val === 'string' ? val : '';
+		} catch {
+			return '';
+		}
+	}
+}
